<FindBugsFilter>
    <!-- Exclude EI_EXPOSE_REP2 in BearerInterceptor constructor -->
    <Match>
        <Class name="org.wso2.keycloak.client.BearerInterceptor"/>
        <Method name="&lt;init&gt;"/>
        <Bug pattern="EI_EXPOSE_REP2"/>
    </Match>

    <!-- Exclude EI_EXPOSE_REP in KeycloakClient.getKeyManagerConfiguration() -->
    <Match>
        <Class name="org.wso2.keycloak.client.KeycloakClient"/>
        <Method name="getKeyManagerConfiguration"/>
        <Bug pattern="EI_EXPOSE_REP"/>
    </Match>

    <!-- Exclude EI_EXPOSE_REP2 in KeycloakClient.loadConfiguration() -->
    <Match>
        <Class name="org.wso2.keycloak.client.KeycloakClient"/>
        <Method name="loadConfiguration"/>
        <Bug pattern="EI_EXPOSE_REP2"/>
    </Match>

    <!-- Exclude UWF_FIELD_NOT_INITIALIZED_IN_CONSTRUCTOR in KeycloakClient -->
    <Match>
        <Class name="org.wso2.keycloak.client.KeycloakClient"/>
        <Field name="introspectionClient"/>
        <Bug pattern="UWF_FIELD_NOT_INITIALIZED_IN_CONSTRUCTOR"/>
    </Match>

    <!-- Exclude EI_EXPOSE_REP in ClientInfo.getCallBackUrls() -->
    <Match>
        <Class name="org.wso2.keycloak.client.model.ClientInfo"/>
        <Method name="getCallBackUrls"/>
        <Bug pattern="EI_EXPOSE_REP"/>
    </Match>

    <!-- Exclude EI_EXPOSE_REP in ClientInfo.getGrantTypes() -->
    <Match>
        <Class name="org.wso2.keycloak.client.model.ClientInfo"/>
        <Method name="getGrantTypes"/>
        <Bug pattern="EI_EXPOSE_REP"/>
    </Match>

    <!-- Exclude EI_EXPOSE_REP in ClientInfo.getResponseTypes() -->
    <Match>
        <Class name="org.wso2.keycloak.client.model.ClientInfo"/>
        <Method name="getResponseTypes"/>
        <Bug pattern="EI_EXPOSE_REP"/>
    </Match>

    <!-- Exclude EI_EXPOSE_REP2 in ClientInfo.setCallBackUrls() -->
    <Match>
        <Class name="org.wso2.keycloak.client.model.ClientInfo"/>
        <Method name="setCallBackUrls"/>
        <Bug pattern="EI_EXPOSE_REP2"/>
    </Match>

    <!-- Exclude EI_EXPOSE_REP2 in ClientInfo.setGrantTypes() -->
    <Match>
        <Class name="org.wso2.keycloak.client.model.ClientInfo"/>
        <Method name="setGrantTypes"/>
        <Bug pattern="EI_EXPOSE_REP2"/>
    </Match>

    <!-- Exclude EI_EXPOSE_REP2 in ClientInfo.setResponseTypes() -->
    <Match>
        <Class name="org.wso2.keycloak.client.model.ClientInfo"/>
        <Method name="setResponseTypes"/>
        <Bug pattern="EI_EXPOSE_REP2"/>
    </Match>
</FindBugsFilter>
